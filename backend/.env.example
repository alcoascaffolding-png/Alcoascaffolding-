# Backend (legacy Express) — copy to backend/.env

APP_ENV=development
NODE_ENV=development
PORT=5000

# Same Atlas cluster; different database per environment
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@alcoa-db.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=alcoa-admin-dev

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

FRONTEND_URL=http://localhost:5173

EMAIL_USER=
EMAIL_PASS=

COMPANY_NAME=Alcoa Aluminium Scaffolding
LOG_LEVEL=info
TIMEZONE=Asia/Dubai
