# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-run-openssl-rand-base64-32

# Database (include DB name in the path, OR set MONGODB_DB_NAME — must match seed script)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/alcoa-admin?retryWrites=true&w=majority
# Optional: if your URI has no database path (e.g. ends with .net/?), Mongoose defaults to "test".
# MONGODB_DB_NAME=alcoa-admin

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@alcoascaffolding.com
COMPANY_EMAIL=sales@alcoascaffolding.com
SUPPORT_EMAIL=support@alcoascaffolding.com

# Twilio (WhatsApp) — SID must start with AC; no quotes or spaces around values
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# PDF (Chromium — leave blank locally if `npx playwright install chromium` was run)
# On Vercel, the app defaults to the Sparticuz x64 pack matching @sparticuz/chromium-min.
# Override if that download fails or you are on arm64 (use the matching *-pack.arm64.tar from Sparticuz releases).
CHROMIUM_EXECUTABLE_PATH=
CHROMIUM_TAR_URL=

# Vercel Blob (required for WhatsApp **with PDF** — token from the SAME Vercel project as the store; recreate if you see "store does not exist")
# Local: run `vercel link` + `vercel env pull` in alcoa-admin, or paste the token from Vercel → Storage → Blob.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxx

# Local dev only: send WhatsApp **text only** (no PDF/Blob). Set to true when you have Twilio set up but no valid Blob token on localhost. Never set on Vercel.
WHATSAPP_LOCAL_TEXT_ONLY=

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxx

# Public (inlined at build — set in Vercel before deploy, or use FEATURES below)
NEXT_PUBLIC_APP_NAME=Alcoa Scaffolding Admin
NEXT_PUBLIC_SITE_URL=https://admin.alcoascaffolding.com
NEXT_PUBLIC_FEATURES=whatsapp,pdf-email

# Server-only UI flags (read at runtime on Vercel — not baked into the client bundle)
# Use this if you added NEXT_PUBLIC_FEATURES after deploy: FEATURES=whatsapp,pdf-email
FEATURES=
SERVER_FEATURES=

# Setup API guard (one-time admin creation)
SETUP_SECRET=change-this-to-a-random-string
