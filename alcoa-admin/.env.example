# =============================================================================
# Alcoa Admin — Environment variables (copy to .env.local)
# =============================================================================
# cp .env.example .env.local
#
# MongoDB Atlas: cluster "alcoa-db" hosts separate DATABASES (not collections):
#   alcoa-admin-dev  → development / testing
#   alcoa-admin-prod → live production site
# =============================================================================

# --- App environment (controls default database when MONGODB_DB_NAME is unset) ---
APP_ENV=development
NODE_ENV=development

# --- MongoDB (same cluster user; different database per environment) ---
# Use URI without a database path, then set MONGODB_DB_NAME (recommended):
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@alcoa-db.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=alcoa-admin-dev

# Or embed the database in the URI (MONGODB_DB_NAME overrides this if set):
# MONGODB_URI=mongodb+srv://USER:PASS@alcoa-db.xxxxx.mongodb.net/alcoa-admin-dev?retryWrites=true&w=majority

# Safety overrides (avoid in normal use):
# MONGODB_ALLOW_PROD_IN_DEV=true
# MONGODB_ALLOW_DEV_IN_PRODUCTION=true

# Windows / Atlas SRV DNS (if connection fails on Windows)
# NODE_OPTIONS=--dns-result-order=ipv4first

# --- Auth (NextAuth) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-long-random-secret-here

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Sales@alcoascaffolding.com
COMPANY_EMAIL=sales@alcoascaffolding.com
COMPANY_NAME=Alcoa Aluminium scaffolding L.L.C
COMPANY_TRN=105075887700001
# Optional: absolute HTTPS URL for logo in emails (else inline CID from public/brand/quotation-logo.png)
# EMAIL_LOGO_URL=https://your-admin-domain.com/brand/quotation-logo.png

# WhatsApp UI + send APIs (false = hide buttons on quotations/orders/invoices)
WHATSAPP_UI_AND_API_ENABLED=false

# --- Optional: Vercel Blob, Upstash, Twilio, etc. ---
# BLOB_READ_WRITE_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
