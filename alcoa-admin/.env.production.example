# Production deployment (Vercel / hosting dashboard — NOT committed)
# Set these in Vercel → Project → Settings → Environment Variables (Production only)

APP_ENV=production
NODE_ENV=production

MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@alcoa-db.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=alcoa-admin-prod

NEXTAUTH_URL=https://admin.alcoascaffolding.com
NEXTAUTH_SECRET=use-a-strong-unique-production-secret

RESEND_API_KEY=
# Hide WhatsApp on production until ready (set true to enable)
WHATSAPP_UI_AND_API_ENABLED=false

RESEND_FROM_EMAIL=Sales@alcoascaffolding.com
COMPANY_EMAIL=sales@alcoascaffolding.com
COMPANY_NAME=Alcoa Aluminium scaffolding L.L.C
