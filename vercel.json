{
  "buildCommand": "npm install --prefix frontend && npm run build --prefix frontend",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install --prefix frontend",
  "framework": null,
  "build": {
    "env": {
      "NODE_OPTIONS": "--max-old-space-size=8192"
    }
  },
  "rewrites": [
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt|llms\\.txt|llms-full\\.txt|logo\\.jpeg|assets/).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/alcoa-scaffolding",
      "destination": "/about-us",
      "permanent": true
    },
    {
      "source": "/scaffolding-rental-dubai",
      "destination": "/scaffolding-rental-abu-dhabi",
      "permanent": true
    },
    {
      "source": "/aluminum-scaffolding-dubai",
      "destination": "/aluminum-scaffolding-abu-dhabi",
      "permanent": true
    },
    {
      "source": "/blog/scaffolding-rental-cost-dubai-2026",
      "destination": "/blog/scaffolding-rental-cost-abu-dhabi-2026",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
