# Copy to .env and adjust. See src/config/env.js for behavior.

VITE_API_URL=http://localhost:5000/api
VITE_ENV=development
VITE_APP_NAME=Alcoa Scaffolding
VITE_SITE_URL=http://localhost:5173

# --- Contact & Quick Quote → alcoa-admin Contact Messages ---
# Production (required for public domain): origin of your deployed Next admin, no trailing slash.
# Example: https://your-admin.vercel.app
# VITE_CONTACT_INGEST_ORIGIN=

# Optional alias for the same value (either may be set).
# VITE_ADMIN_APP_ORIGIN=

# Local/LAN: if unset, forms use http://<site-host>:3000 (e.g. localhost:3000 or 192.168.x.x:3000).
# Override if alcoa-admin runs on another port or URL:
# VITE_LOCAL_ADMIN_ORIGIN=http://localhost:3001
